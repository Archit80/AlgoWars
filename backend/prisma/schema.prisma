generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

model User {
  id               String            @id
  email            String            @unique
  username         String?            @unique
  xp               Int               @default(0)
  streak           Int               @default(0)
  matches1         Match[]           @relation("User1")
  matches2         Match[]           @relation("User2")
  soloSessions     SoloSession[]
  userAchievements UserAchievement[]
}

model Question {
  id         String       @id @default(uuid())
  text       String
  type       QuestionType // MCQ or PredictOutput or FillBlank etc.
  categories String[]
  options    String[] // for MCQs
  answer     String
  matches    Match[]
  difficulty Difficulty
  createdAt  DateTime     @default(now())
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ
  FILL_BLANK
  PREDICT_OUTPUT
}

model Match {
  id         String   @id @default(uuid())
  user1      User     @relation("User1", fields: [user1Id], references: [id])
  user1Id    String
  user2      User     @relation("User2", fields: [user2Id], references: [id])
  user2Id    String
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
  winnerId   String?
  createdAt  DateTime @default(now())
}

model SoloSession {
  id             Int       @id @default(autoincrement())
  user           User      @relation(fields: [userId], references: [id])
  userId         String
  totalQuestions Int
  correctAnswers Int
  duration       Int? // in seconds, if using Timed mode
  mode           SoloMode
  difficulty     String // easy, medium, hard
  categories     String[] // array of selected topics/categories
  xpEarned       Int       @default(0)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
}

enum SoloMode {
  TIMED
  ACCURACY
}

model Achievement {
  id          String @id @default(cuid())
  name        String
  slug        String @unique // e.g. 'big-brain'
  emoji       String
  description String
  goal        Int
  type        String // e.g. 'quiz', 'battle', etc

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  progress      Int      @default(0)
  unlocked      Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId]) // so 1 user can't have same achievement multiple times
}
