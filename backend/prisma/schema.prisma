generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
        

model User {
  id               String            @id
  email            String            @unique
  username         String?           @unique
  profilePic       String?  

  xp               Int               @default(0)
  streak           Int               @default(0)
  longestStreak    Int               @default(0)
  isOnboarded      Boolean           @default(false)

  // Explicit counters for fast access
  totalMatches     Int               @default(0)
  matchesWon       Int               @default(0)
  matchesLost      Int               @default(0)
  correctAnswers   Int               @default(0)
  totalAnswers     Int               @default(0)
  lastMatchAt      DateTime?

  matches1         Match[]           @relation("User1")
  matches2         Match[]           @relation("User2")
  soloSessions     SoloSession[]
  userAchievements UserAchievement[]
  matchAnswers     MatchAnswer[]
  savedQuestions   SavedQuestion[]
}

model Question {
  id         String       @id @default(uuid())
  text       String       @unique
  type       QuestionType // MCQ or PredictOutput or FillBlank etc.
  categories String[]
  options    String[] // for MCQs
  answer     String
  matches    Match[]      @relation("MatchQuestions")
  difficulty Difficulty
  createdAt  DateTime     @default(now())
  matchAnswers MatchAnswer[]
  savedQuestions SavedQuestion[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ
  FILL_BLANK
  PREDICT_OUTPUT
}

model Match {
  id         String   @id @default(uuid())
  user1      User     @relation("User1", fields: [user1Id], references: [id])
  user1Id    String
  user2      User?    @relation("User2", fields: [user2Id], references: [id])
  user2Id    String?

  user1Score   Int      @default(0)     // NEW
  user2Score   Int      @default(0)     // NEW
  currentIndex Int      @default(0)     // NEW (0-based)

  questions  Question[] @relation("MatchQuestions")

  // 1v1 battle fields
  categories String[]
  difficulty Difficulty
  isPrivate  Boolean  @default(false)
  roomCode   String?  @unique

  winnerId   String?
  status     MatchStatus @default(WAITING)
  createdAt  DateTime @default(now())

  answers    MatchAnswer[]
}


enum MatchStatus {
  WAITING
  ONGOING
  COMPLETED
}


model SoloSession {
  id             Int          @id @default(autoincrement())
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  totalQuestions Int
  correctAnswers Int
  duration       Int? // in seconds, if using Timed mode
  mode           SoloMode
  difficulty     String // easy, medium, hard
  categories     String[] // array of selected topics/categories
  xpEarned       Int          @default(0)
  startedAt      DateTime     @default(now())
  endedAt        DateTime?
  
  answers        SoloAnswer[]
}

enum SoloMode {
  TIMED
  ACCURACY
}

model Achievement {
  id          String @id @default(cuid())
  name        String
  slug        String @unique // e.g. 'big-brain'
  emoji       String
  description String
  goal        Int
  type        String // e.g. 'quiz', 'battle', etc

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  progress      Int      @default(0)
  unlocked      Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId]) // so 1 user can't have same achievement multiple times
}

// Stores each user's answer per question in a match
model MatchAnswer {
  id         String   @id @default(uuid())
  match      Match    @relation(fields: [matchId], references: [id])
  matchId    String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
  answer     String
  correct    Boolean
  createdAt  DateTime @default(now())

  @@unique([matchId, userId, questionId])
}

// Stores each user's answer per question in a solo session
model SoloAnswer {
  id            String      @id @default(uuid())
  soloSession   SoloSession @relation(fields: [soloSessionId], references: [id])
  soloSessionId Int
  questionId    String
  questionText  String
  questionOptions String[] // Store the options as they were when answered
  correctAnswer String
  userAnswer    String?
  correct       Boolean
  createdAt     DateTime @default(now())

  @@unique([soloSessionId, questionId])
}

// Stores each user's saved questions
model SavedQuestion {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  question      Question @relation(fields: [questionId], references: [id])
  questionId    String
  savedFrom     String?
  userAnswer    String?
  wasCorrect    Boolean?
  createdAt     DateTime @default(now())

  @@unique([userId, questionId])
}
